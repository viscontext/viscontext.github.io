---
import ProjectVisual from "../components/ProjectVisual.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { records } from "../lib/data";

const projects = [...records].sort((a, b) => a.work.title.localeCompare(b.work.title));
const topics = [...new Set(projects.map((record) => record.work.topic))].sort();
const types = [...new Set(projects.map((record) => record.work.type))].sort();
const providers = [...new Set(projects.flatMap((record) => record.provenance ? [record.provenance.provider] : []))].sort();
---

<BaseLayout title="Visualization project repository" description="Browse visualization projects and inspect their context metadata.">
  <header class="page-heading shell">
    <div>
      <p class="prototype-label">Functional prototype · fictional and sourced records</p>
      <h1>Visualization project repository</h1>
      <p>Browse visualization projects and inspect the context metadata provided alongside them.</p>
    </div>
    <a class="button" href="/upload/">Upload a project</a>
  </header>

  <section class="catalog shell" aria-labelledby="catalog-title">
    <h2 id="catalog-title" class="visually-hidden">Project catalog</h2>
    <div class="catalog-controls" role="search">
      <label>
        Search projects
        <input id="catalog-search" type="search" placeholder="Title, author, or description" autocomplete="off" />
      </label>
      <label>
        Topic
        <select id="topic-filter">
          <option value="">All topics</option>
          {topics.map((topic) => <option value={topic}>{topic}</option>)}
        </select>
      </label>
      <label>
        Format
        <select id="type-filter">
          <option value="">All formats</option>
          {types.map((type) => <option value={type}>{type}</option>)}
        </select>
      </label>
      <label>
        Record origin
        <select id="origin-filter">
          <option value="">All records</option>
          <option value="imported">Real source records</option>
          <option value="fictional">Fictional examples</option>
        </select>
      </label>
      <label>
        Source platform
        <select id="provider-filter">
          <option value="">All platforms</option>
          {providers.map((provider) => <option value={provider}>{provider}</option>)}
        </select>
      </label>
    </div>

    <div class="catalog-summary">
      <strong id="result-count">{projects.length} projects</strong>
      <span>Each project includes visualization context supplied as structured metadata.</span>
    </div>

    <ul class="project-grid" id="project-grid">
      {projects.map((record) => {
        const author = record.contributors[0]?.displayName ?? "Unknown author";
        const description = String(record.sections.project?.description ?? "");
        const visualizationCount = record.visualizations.totalCount;
        const visualizationTitles = record.visualizations.items.map((item) => item.title).join(" ");
        const origin = record.work.fictional ? "fictional" : "imported";
        const provider = record.provenance?.provider ?? "";
        return (
          <li
            class="project-card"
            data-topic={record.work.topic}
            data-type={record.work.type}
            data-origin={origin}
            data-provider={provider}
            data-search={`${record.work.title} ${author} ${provider} ${description} ${visualizationTitles}`.toLowerCase()}
          >
            <a class="visual-link" href={`/records/${record.id}/`} tabindex="-1" aria-hidden="true">
              <ProjectVisual compact fictional={record.work.fictional} kind={record.work.visualKind} title={record.work.title} />
            </a>
            <div class="card-content">
              <div class="card-tags"><span class="origin-tag">{origin === "imported" ? "real source" : "fictional"}</span><span>{record.work.topic}</span><span>{record.work.type}</span><span>{record.work.year}</span></div>
              <h3><a href={`/records/${record.id}/`}>{record.work.title}</a></h3>
              <p class="card-author">By {author}</p>
              <p>{description}</p>
              <p class="context-count">
                {visualizationCount} {visualizationCount === 1 ? "visualization" : "visualizations"}
                {" · "}{Object.values(record.sections).reduce((count, section) => count + Object.keys(section).length, 0)} project context fields
              </p>
            </div>
          </li>
        );
      })}
    </ul>
    <p id="empty-state" class="empty-state" hidden>No projects match the current filters.</p>
  </section>

  <script>
    function requiredElement<T extends Element>(selector: string): T {
      const element = document.querySelector<T>(selector);
      if (!element) throw new Error(`Missing catalog element: ${selector}`);
      return element;
    }

    const search = requiredElement<HTMLInputElement>('#catalog-search');
    const topic = requiredElement<HTMLSelectElement>('#topic-filter');
    const type = requiredElement<HTMLSelectElement>('#type-filter');
    const origin = requiredElement<HTMLSelectElement>('#origin-filter');
    const provider = requiredElement<HTMLSelectElement>('#provider-filter');
    const cards = [...document.querySelectorAll<HTMLElement>('.project-card')];
    const count = requiredElement<HTMLElement>('#result-count');
    const empty = requiredElement<HTMLElement>('#empty-state');

    function updateCatalog() {
      const query = search.value.trim().toLowerCase();
      let visible = 0;
      for (const card of cards) {
        const matchesSearch = !query || (card.dataset.search ?? '').includes(query);
        const matchesTopic = !topic.value || card.dataset.topic === topic.value;
        const matchesType = !type.value || card.dataset.type === type.value;
        const matchesOrigin = !origin.value || card.dataset.origin === origin.value;
        const matchesProvider = !provider.value || card.dataset.provider === provider.value;
        card.hidden = !(matchesSearch && matchesTopic && matchesType && matchesOrigin && matchesProvider);
        if (!card.hidden) visible += 1;
      }
      count.textContent = `${visible} ${visible === 1 ? 'project' : 'projects'}`;
      empty.hidden = visible !== 0;
    }

    search.addEventListener('input', updateCatalog);
    topic.addEventListener('change', updateCatalog);
    type.addEventListener('change', updateCatalog);
    origin.addEventListener('change', updateCatalog);
    provider.addEventListener('change', updateCatalog);
  </script>
</BaseLayout>
