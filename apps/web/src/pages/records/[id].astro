---
import MetadataTable from "../../components/MetadataTable.astro";
import ProjectVisual from "../../components/ProjectVisual.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { framework, getRecordPreview, getVisualizationPreview, records, type ContextRecord } from "../../lib/data";

export function getStaticPaths() {
  return records.map((record) => ({ params: { id: record.id }, props: { record } }));
}

interface Props { record: ContextRecord }
const { record } = Astro.props;
const author = record.contributors[0]?.displayName ?? "Unknown author";
const isImported = !record.work.fictional && Boolean(record.provenance);
const hasMedia = record.visualizations.items.some((visualization) => visualization.media);
const previewImage = getRecordPreview(record);
const formatCount = (count: number) => new Intl.NumberFormat("en").format(count);
---

<BaseLayout title={record.work.title} description={String(record.sections.project?.description ?? "Visualization project context")}>
  <div class="shell breadcrumbs"><a href="/">All projects</a> / <span>{record.work.title}</span></div>

  <article class="project-detail shell">
    <header class="detail-heading">
      <div>
        <p class="prototype-label">{isImported ? "Imported real-world record" : "Fictional catalog record"}</p>
        <h1>{record.work.title}</h1>
        <p>By {author}</p>
      </div>
      <div class="detail-tags"><span>{record.work.topic}</span><span>{record.work.type}</span><span>{record.work.year}</span></div>
    </header>

    <div class="project-overview">
      <ProjectVisual fictional={record.work.fictional} imageUrl={previewImage} kind={record.work.visualKind} title={record.work.title} />
      <aside>
        <h2>Project summary</h2>
        <p>{String(record.sections.project?.description)}</p>
        <dl>
          <div><dt>Author</dt><dd>{author}</dd></div>
          <div><dt>Published</dt><dd>{String(record.sections.project?.publicationDate ?? "Not provided")}</dd></div>
          <div><dt>License</dt><dd>{String(record.sections.project?.license ?? "Not provided")}</dd></div>
          <div><dt>Record origin</dt><dd>{isImported ? `Imported from ${record.provenance?.provider}` : "Fictional example"}</dd></div>
          <div><dt>Context framework</dt><dd>{record.frameworkVersion} (experimental)</dd></div>
        </dl>
        <a class="button secondary" href={record.work.canonicalUrl}>Open original project</a>
      </aside>
    </div>

    {record.provenance && (
      <section class="provenance-section" aria-labelledby="provenance-heading">
        <div class="context-heading-row">
          <div>
            <h2 id="provenance-heading">Source provenance</h2>
            <p>This record normalizes external metadata. It is not a claim that the original author completed this framework.</p>
          </div>
          <a href={record.provenance.sourceUrl}>Open authoritative source</a>
        </div>
        <dl class="provenance-grid">
          <div><dt>Provider</dt><dd>{record.provenance.provider}</dd></div>
          <div><dt>External ID</dt><dd>{record.provenance.externalId}</dd></div>
          <div><dt>Retrieved</dt><dd>{record.provenance.retrievedAt}</dd></div>
          <div><dt>Source updated</dt><dd>{record.provenance.sourceUpdatedAt ?? "Not provided"}</dd></div>
          <div class="wide"><dt>Attribution</dt><dd>{record.provenance.attribution}</dd></div>
          {record.provenance.metadataUrl && <div class="wide"><dt>Machine metadata</dt><dd><a href={record.provenance.metadataUrl}>{record.provenance.metadataUrl}</a></dd></div>}
          {record.provenance.archivedUrl && <div class="wide"><dt>Archived source</dt><dd><a href={record.provenance.archivedUrl}>{record.provenance.archivedUrl}</a></dd></div>}
        </dl>
        <h3>Normalization notes</h3>
        <ul>{record.provenance.normalizationNotes.map((note) => <li>{note}</li>)}</ul>
        <details class="contributor-details">
          <summary>{record.contributors.length} credited contributors and organizations</summary>
          <ul class="contributor-list">
            {record.contributors.map((contributor) => (
              <li><strong>{contributor.displayName}</strong><span>{contributor.role}{contributor.affiliation ? ` · ${contributor.affiliation}` : ""}</span></li>
            ))}
          </ul>
        </details>
      </section>
    )}

    {(record.visualizations.totalCount > 1 || hasMedia) && (
      <section class="visualization-index" aria-labelledby="visualization-index-heading">
        <div class="context-heading-row">
          <div>
            <h2 id="visualization-index-heading">Visualizations and media</h2>
            <p>
              {record.visualizations.listingMode === "sampled"
                ? `Showing ${record.visualizations.items.length} representative items from a collection of ${record.visualizations.totalCount}. A production index would be paginated.`
                : record.visualizations.totalCount === 1
                  ? "One visualization is listed. Its downloadable files and renditions remain media assets, not additional visualizations."
                  : `${record.visualizations.totalCount} visualizations are listed in project order.`}
            </p>
          </div>
          <strong>{record.visualizations.totalCount} total</strong>
        </div>
        <ol class="visualization-grid">
          {record.visualizations.items.map((visualization) => (
            <li>
              <ProjectVisual compact fictional={record.work.fictional} imageUrl={getVisualizationPreview(visualization)} kind={visualization.visualKind} title={visualization.title} />
              <div class="visualization-content">
                <h3>{visualization.title}</h3>
                <p>{visualization.description}</p>
                {visualization.context && (
                  <details>
                    <summary>Visualization-specific context</summary>
                    <dl>
                      {visualization.context.chartType && <div><dt>Chart type</dt><dd>{visualization.context.chartType}</dd></div>}
                      {visualization.context.visualEncoding && <div><dt>Visual encoding</dt><dd>{visualization.context.visualEncoding}</dd></div>}
                      {visualization.context.knownLimitations && <div><dt>Limitations</dt><dd>{visualization.context.knownLimitations}</dd></div>}
                    </dl>
                  </details>
                )}
                {visualization.media && (
                  <div class="media-assets">
                    <h4>Source media <small>({visualization.media.selection})</small></h4>
                    <ul>
                      {visualization.media.items.map((asset) => {
                        const details = [asset.format, asset.dimensions, asset.fileSize, asset.itemCount ? `${formatCount(asset.itemCount)} items` : undefined].filter(Boolean).join(" · ");
                        return (
                          <li>
                            <div>{asset.url ? <a href={asset.url}>{asset.label}</a> : <strong>{asset.label}</strong>}<span>{asset.kind}</span></div>
                            {details && <p>{details}</p>}
                            {asset.description && <p>{asset.description}</p>}
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    <section class="context-section" aria-labelledby="context-heading">
      <div class="context-heading-row">
        <div><h2 id="context-heading">Shared project context</h2><p>{framework.presentation.record.frameworkNotice} These values apply across the project unless a visualization states otherwise.</p></div>
        <a href="/framework/">View framework fields</a>
      </div>
      <MetadataTable sections={framework.presentation.sections} values={record.sections} />
    </section>

    <div class="detail-actions">
      <a href={`/api/v1/records/${record.id}.json`}>Download this record as JSON</a>
      <a href="/">Back to catalog</a>
    </div>
  </article>
</BaseLayout>
