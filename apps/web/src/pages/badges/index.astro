---
import BadgeEmbedPanel from "../../components/BadgeEmbedPanel.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Visualization badges" description="Download and embed VisContext metadata badges.">
  <header class="page-heading shell simple-heading">
    <div>
      <p class="prototype-label">Badge prototype</p>
      <h1>Visualization badges</h1>
      <p>Download small attribution badges that can link from a visualization back to its context metadata record.</p>
    </div>
  </header>

  <div class="badge-content shell">
    <BadgeEmbedPanel
      heading="Generic badge variants"
      intro="Use these generic badge assets with a link to the matching VisContext record. Replace YOUR-RECORD-ID in the snippets with the project record slug."
    />

    <section class="badge-section" aria-labelledby="future-badge-work">
      <h2 id="future-badge-work">Still future work</h2>
      <ul>
        <li>Generated record-specific badge assets once publishing and review workflows exist.</li>
        <li>Badge status text that can expose record state and framework version without implying truth verification.</li>
        <li>A stable name, criteria, issuer, and supersession rules.</li>
        <li>PNG exports if needed for platforms that cannot embed SVG.</li>
      </ul>
    </section>
  </div>
</BaseLayout>
