---
interface Props {
  compact?: boolean;
  fictional?: boolean;
  kind: "animation" | "bars" | "dashboard" | "line" | "map" | "scatter" | "small-multiples";
  title: string;
}

const { compact = false, fictional = true, kind, title } = Astro.props;
---

<figure class:list={["project-visual", { compact }]} aria-label={`Catalog schematic for ${title}`}>
  <svg viewBox="0 0 640 360" role="img" aria-hidden="true">
    <rect class="visual-background" x="0" y="0" width="640" height="360"></rect>
    {kind === "line" && (
      <g class="line-visual">
        <path d="M34 278 H610 M34 206 H610 M34 134 H610 M34 62 H610"></path>
        <polyline points="34,250 110,215 186,235 262,172 338,191 414,112 490,145 566,76 610,95"></polyline>
        <polyline points="34,186 110,154 186,169 262,119 338,150 414,132 490,78 566,108 610,68"></polyline>
      </g>
    )}
    {kind === "bars" && (
      <g class="bar-visual">
        <rect x="46" y="88" width="396" height="30"></rect><rect x="46" y="142" width="512" height="30"></rect>
        <rect x="46" y="196" width="302" height="30"></rect><rect x="46" y="250" width="448" height="30"></rect>
      </g>
    )}
    {kind === "scatter" && (
      <g class="scatter-visual">
        <path d="M50 300 H600 M50 300 V42"></path>
        <circle cx="115" cy="251" r="12"></circle><circle cx="181" cy="222" r="18"></circle><circle cx="243" cy="246" r="9"></circle>
        <circle cx="304" cy="170" r="14"></circle><circle cx="372" cy="191" r="22"></circle><circle cx="436" cy="115" r="11"></circle>
        <circle cx="511" cy="92" r="17"></circle><circle cx="558" cy="62" r="8"></circle>
      </g>
    )}
    {kind === "map" && (
      <g class="map-visual">
        <path d="M53 89 L180 44 267 82 344 49 446 88 584 67 604 173 523 203 475 302 355 271 249 322 155 266 59 281Z"></path>
        <path d="M180 44 L204 150 155 266 M267 82 L204 150 355 271 M344 49 L367 151 475 302 M446 88 L367 151 523 203 M59 281 L204 150 367 151 584 67"></path>
      </g>
    )}
    {kind === "dashboard" && (
      <g class="dashboard-visual">
        <rect x="36" y="42" width="178" height="116"></rect><rect x="232" y="42" width="372" height="116"></rect>
        <rect x="36" y="178" width="272" height="140"></rect><rect x="326" y="178" width="278" height="140"></rect>
        <path d="M252 128 L295 102 340 118 391 72 446 91 505 62 578 84"></path>
        <rect x="58" y="232" width="48" height="62"></rect><rect x="119" y="208" width="48" height="86"></rect><rect x="180" y="251" width="48" height="43"></rect>
      </g>
    )}
    {kind === "small-multiples" && (
      <g class="multiples-visual">
        {[0, 1, 2, 3, 4, 5].map((item) => {
          const x = 35 + (item % 3) * 202;
          const y = 38 + Math.floor(item / 3) * 156;
          return <g><rect x={x} y={y} width="170" height="126"></rect><polyline points={`${x + 12},${y + 98} ${x + 45},${y + 72} ${x + 78},${y + 84} ${x + 112},${y + 44} ${x + 157},${y + 58}`}></polyline></g>;
        })}
      </g>
    )}
    {kind === "animation" && (
      <g class="animation-visual">
        <circle cx="320" cy="180" r="116"></circle>
        <path d="M206 170 C258 124 382 124 434 170 M213 222 C270 256 370 256 427 222"></path>
        <path d="M320 64 C270 105 270 255 320 296 M320 64 C370 105 370 255 320 296"></path>
        <path class="motion-path" d="M124 116 C180 56 246 58 276 94 M516 246 C464 304 395 302 366 270"></path>
        <path class="play-mark" d="M298 144 L370 180 L298 216 Z"></path>
      </g>
    )}
  </svg>
  <figcaption>{title} — {fictional ? "fictional preview" : "catalog schematic; open the source for the original"}</figcaption>
</figure>
