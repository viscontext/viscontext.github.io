---
import type { PresentationSection } from "../lib/data";

interface Props {
  index: number;
  section: PresentationSection;
  values: Record<string, unknown>;
}

const { index, section, values } = Astro.props;
---

<section class="record-section" aria-labelledby={`section-${section.id}`}>
  <div class="section-heading">
    <span class="section-number" aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
    <div>
      <h2 id={`section-${section.id}`}>{section.label}</h2>
      <p>{section.description}</p>
    </div>
  </div>
  <dl class="field-list">
    {section.fields.map((field) => (
      <div class="field-row">
        <dt>
          <span>{field.label}</span>
          <small>{field.help}</small>
        </dt>
        <dd>
          {field.valueType === "url" && typeof values[field.id] === "string" ? (
            <a href={String(values[field.id])}>{String(values[field.id])}</a>
          ) : (
            String(values[field.id] ?? "Not provided")
          )}
        </dd>
      </div>
    ))}
  </dl>
</section>
